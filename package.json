{
  "name": "@_molaidrislabs/react-native-internet-speed-test",
  "version": "0.1.2",
  "description": "JavaScript-first NDT7 client for React Native and React Native Web.",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "import": {
        "default": "./lib/module/index.js"
      },
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "README.md",
    "LICENSE",
    "babel.config.js",
    "tsconfig.json",
    "tsconfig.build.json",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "lint": "tsc --noEmit",
    "prepare": "yarn build",
    "prepack": "yarn clean",
    "prepublishOnly": "yarn test && yarn typecheck",
    "pack:dry-run": "npm pack --dry-run",
    "release:check": "yarn test && yarn typecheck && yarn pack:dry-run",
    "test": "vitest run tests",
    "test:watch": "vitest tests",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true,
          "sourcemap": false
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "keywords": [
    "react-native",
    "react-native-web",
    "ndt7",
    "network-speed",
    "internet-speed"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanmi-idris/react-native-ndt7-js.git"
  },
  "homepage": "https://github.com/kanmi-idris/react-native-ndt7-js#readme",
  "bugs": {
    "url": "https://github.com/kanmi-idris/react-native-ndt7-js/issues"
  },
  "license": "MIT",
  "author": "Olasunkanmi IDRIS <olasunkanmiidris15@gmail.com>",
  "packageManager": "yarn@1.22.22",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": ">=0.79.0"
  },
  "dependencies": {
    "@m-lab/ndt7": "0.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "^19.0.10",
    "react": "19.0.0",
    "react-native": "0.79.5",
    "react-native-builder-bob": "^0.36.0",
    "typescript": "~5.8.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
